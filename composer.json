{
    "name": "phosphor/framework",
    "description": "Phosphor — AI 驱动的 PHP 框架核心",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Phosphor\\": "src/"
        },
        "files": [
            "src/Config/helpers.php"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
