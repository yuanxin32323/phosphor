{
    "name": "phosphor/framework",
    "description": "Phosphor - AI 驱动的 PHP 框架。显式、可预测、自描述。",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "symfony/yaml": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Phosphor\\": "src/",
            "Shared\\": "shared/",
            "Apps\\": "apps/"
        },
        "files": [
            "src/Config/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": "find src shared apps -name '*.php' -exec php -l {} \\;"
    },
    "config": {
        "sort-packages": true
    }
}
